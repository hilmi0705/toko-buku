<%- include('../../partials/admin-header') %>

<div class="d-flex align-items-center gap-3 mb-4">
    <a href="/admin/buku" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
    <h4 class="fw-bold mb-0">Edit Buku</h4>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-4">
        <form action="/admin/buku/edit/<%= buku.id %>" method="POST" enctype="multipart/form-data">
            <div class="row g-4">
                <div class="col-md-8">
                    <div class="mb-3">
                        <label class="form-label fw-medium">Judul Buku <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" name="judul" value="<%= buku.judul %>" required>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-medium">Penulis <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="penulis" value="<%= buku.penulis %>" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium">Penerbit</label>
                            <input type="text" class="form-control" name="penerbit" value="<%= buku.penerbit || '' %>">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-medium">Tahun Terbit</label>
                            <input type="number" class="form-control" name="tahun_terbit" value="<%= buku.tahun_terbit || '' %>" min="1900" max="<%= new Date().getFullYear() %>">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-medium">ISBN</label>
                            <input type="text" class="form-control" name="isbn" value="<%= buku.isbn || '' %>">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-medium">Kategori <span class="text-danger">*</span></label>
                            <select class="form-select" name="kategori_id" required>
                                <% kategoris.forEach(k => { %>
                                <option value="<%= k.id %>" <%= buku.kategori_id == k.id ? 'selected' : '' %>><%= k.nama %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium">Harga (Rp) <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" name="harga" value="<%= buku.harga %>" min="0" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium">Stok</label>
                            <input type="number" class="form-control" name="stok" value="<%= buku.stok %>" min="0">
                        </div>
                    </div>
                    <div class="mt-3">
                        <label class="form-label fw-medium">Deskripsi</label>
                        <textarea class="form-control" name="deskripsi" rows="4"><%= buku.deskripsi || '' %></textarea>
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-medium">Cover Buku</label>
                    <div class="border rounded p-3 text-center">
                        <img id="previewImg" src="/images/<%= buku.gambar %>" class="img-fluid rounded mb-3"
                             style="max-height:200px;object-fit:cover" onerror="this.src='/images/default-book.jpg'">
                        <input type="file" class="form-control form-control-sm" name="gambar" accept="image/*" onchange="previewImage(this)">
                        <small class="text-muted mt-1 d-block">Kosongkan jika tidak ingin mengganti gambar</small>
                    </div>
                </div>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary px-4"><i class="bi bi-save me-2"></i>Perbarui Buku</button>
                <a href="/admin/buku" class="btn btn-outline-secondary">Batal</a>
            </div>
        </form>
    </div>
</div>

<%- include('../../partials/admin-footer') %>
<script>
function previewImage(input) {
    if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = e => document.getElementById('previewImg').src = e.target.result;
        reader.readAsDataURL(input.files[0]);
    }
}
</script>
