<%- include('../../partials/admin-header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">Kelola Pesanan <span class="badge bg-secondary ms-2 fs-6"><%= count %></span></h4>
</div>

<!-- Filter Status -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-3">
        <form action="/admin/pesanan" method="GET" class="d-flex gap-2 flex-wrap align-items-center">
            <select class="form-select w-auto" name="status">
                <option value="">Semua Status</option>
                <option value="menunggu" <%= selectedStatus === 'menunggu' ? 'selected' : '' %>>Menunggu</option>
                <option value="diproses" <%= selectedStatus === 'diproses' ? 'selected' : '' %>>Diproses</option>
                <option value="dikirim" <%= selectedStatus === 'dikirim' ? 'selected' : '' %>>Dikirim</option>
                <option value="selesai" <%= selectedStatus === 'selesai' ? 'selected' : '' %>>Selesai</option>
                <option value="dibatalkan" <%= selectedStatus === 'dibatalkan' ? 'selected' : '' %>>Dibatalkan</option>
            </select>
            <button type="submit" class="btn btn-primary"><i class="bi bi-funnel me-1"></i>Filter</button>
            <a href="/admin/pesanan" class="btn btn-outline-secondary">Reset</a>
        </form>
    </div>
</div>

<!-- Tabel Pesanan -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Kode Pesanan</th>
                        <th>Customer</th>
                        <th>Total Harga</th>
                        <th>Status</th>
                        <th>Tanggal</th>
                        <th class="text-center">Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    <%
                    const statusMap = { 'menunggu':'warning','diproses':'info','dikirim':'primary','selesai':'success','dibatalkan':'danger' };
                    const statusLabel = { 'menunggu':'Menunggu','diproses':'Diproses','dikirim':'Dikirim','selesai':'Selesai','dibatalkan':'Dibatalkan' };
                    %>
                    <% if (pesanans.length === 0) { %>
                    <tr><td colspan="6" class="text-center py-4 text-muted">Tidak ada data pesanan</td></tr>
                    <% } %>
                    <% pesanans.forEach(p => { %>
                    <tr>
                        <td class="fw-medium text-primary"><%= p.kode_pesanan %></td>
                        <td>
                            <div class="fw-medium"><%= p.user ? p.user.nama : '-' %></div>
                            <small class="text-muted"><%= p.user ? p.user.email : '' %></small>
                        </td>
                        <td class="fw-medium"><%- formatRupiah(p.total_harga) %></td>
                        <td>
                            <span class="badge bg-<%= statusMap[p.status] || 'secondary' %> px-2 py-1">
                                <%= statusLabel[p.status] || p.status %>
                            </span>
                        </td>
                        <td><small><%= formatTanggal(p.createdAt) %></small></td>
                        <td class="text-center">
                            <a href="/admin/pesanan/<%= p.id %>" class="btn btn-sm btn-outline-primary me-1">
                                <i class="bi bi-eye"></i>
                            </a>
                            <form action="/admin/pesanan/<%= p.id %>/hapus" method="POST" class="d-inline"
                                  onsubmit="return confirm('Hapus pesanan ini?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Pagination -->
<% if (totalPages > 1) { %>
<nav class="mt-3">
    <ul class="pagination justify-content-center">
        <% for (let i = 1; i <= totalPages; i++) { %>
        <li class="page-item <%= i === currentPage ? 'active' : '' %>">
            <a class="page-link" href="/admin/pesanan?page=<%= i %>&status=<%= selectedStatus %>"><%= i %></a>
        </li>
        <% } %>
    </ul>
</nav>
<% } %>

<%- include('../../partials/admin-footer') %>
