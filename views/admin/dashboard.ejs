<%- include('../partials/admin-header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">Dashboard</h4>
    <small class="text-muted">Selamat datang, <%= user.nama %></small>
</div>

<!-- STAT CARDS -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="stat-icon bg-primary bg-opacity-10 text-primary rounded-3 p-3">
                    <i class="bi bi-book fs-3"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold"><%= totalBuku %></div>
                    <small class="text-muted">Total Buku</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="stat-icon bg-success bg-opacity-10 text-success rounded-3 p-3">
                    <i class="bi bi-people fs-3"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold"><%= totalUser %></div>
                    <small class="text-muted">Total User</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="stat-icon bg-warning bg-opacity-10 text-warning rounded-3 p-3">
                    <i class="bi bi-bag-check fs-3"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold"><%= totalPesanan %></div>
                    <small class="text-muted">Total Pesanan</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="stat-icon bg-info bg-opacity-10 text-info rounded-3 p-3">
                    <i class="bi bi-currency-dollar fs-3"></i>
                </div>
                <div>
                    <div class="fs-5 fw-bold"><%- formatRupiah(pendapatan) %></div>
                    <small class="text-muted">Pendapatan</small>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Pesanan Terbaru -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
        <h6 class="fw-bold mb-0">Pesanan Terbaru</h6>
        <a href="/admin/pesanan" class="btn btn-sm btn-outline-primary">Lihat Semua</a>
    </div>
    <div class="card-body p-0">
        <% if (pesananTerbaru.length === 0) { %>
        <div class="text-center py-4 text-muted">Belum ada pesanan</div>
        <% } else { %>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Kode Pesanan</th>
                        <th>Customer</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th>Tanggal</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    <%
                    const statusMap = { 'menunggu':'warning','diproses':'info','dikirim':'primary','selesai':'success','dibatalkan':'danger' };
                    const statusLabel = { 'menunggu':'Menunggu','diproses':'Diproses','dikirim':'Dikirim','selesai':'Selesai','dibatalkan':'Dibatalkan' };
                    %>
                    <% pesananTerbaru.forEach(p => { %>
                    <tr>
                        <td class="fw-medium"><%= p.kode_pesanan %></td>
                        <td><%= p.user ? p.user.nama : '-' %></td>
                        <td><%- formatRupiah(p.total_harga) %></td>
                        <td><span class="badge bg-<%= statusMap[p.status] %>"><%= statusLabel[p.status] %></span></td>
                        <td><%= formatTanggal(p.createdAt) %></td>
                        <td><a href="/admin/pesanan/<%= p.id %>" class="btn btn-sm btn-outline-secondary">Detail</a></td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
        <% } %>
    </div>
</div>

<%- include('../partials/admin-footer') %>
