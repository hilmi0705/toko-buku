<footer class="mt-5 py-4" id="mainFooter">
    <div class="container">
        <div class="row gy-3">
            <div class="col-md-4">
                <h5 class="fw-bold"><i class="bi bi-book-half me-2"></i>BukuKita</h5>
                <p class="small text-muted">Toko buku online terpercaya. Temukan ribuan judul buku berkualitas dengan harga terjangkau.</p>
            </div>
            <div class="col-md-4">
                <h6 class="fw-semibold mb-3">Kategori</h6>
                <ul class="list-unstyled small">
                    <li><a href="/?kategori=novel" class="footer-link">Novel</a></li>
                    <li><a href="/?kategori=pendidikan" class="footer-link">Pendidikan</a></li>
                    <li><a href="/?kategori=komik" class="footer-link">Komik</a></li>
                </ul>
            </div>
            <div class="col-md-4">
                <h6 class="fw-semibold mb-3">Akun</h6>
                <ul class="list-unstyled small">
                    <% if (user) { %>
                    <li><a href="/keranjang" class="footer-link">Keranjang</a></li>
                    <li><a href="/pesanan" class="footer-link">Riwayat Pesanan</a></li>
                    <li><a href="/auth/logout" class="footer-link">Logout</a></li>
                    <% } else { %>
                    <li><a href="/auth/login" class="footer-link">Login</a></li>
                    <li><a href="/auth/register" class="footer-link">Daftar</a></li>
                    <% } %>
                </ul>
            </div>
        </div>
        <hr class="border-secondary">
        <p class="text-center text-muted small mb-0">&copy; <%= new Date().getFullYear() %> BukuKita. Dibuat dengan ❤️ menggunakan Node.js & Express</p>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
