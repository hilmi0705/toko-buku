<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Toko Buku Online</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<!-- NAVBAR -->
<nav class="navbar navbar-expand-lg navbar-dark sticky-top" id="mainNav">
    <div class="container">
        <a class="navbar-brand fw-bold fs-4" href="/">
            <i class="bi bi-book-half me-2"></i>BukuKita
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <!-- Search -->
            <form class="d-flex mx-auto my-2 my-lg-0" action="/" method="GET" style="width:380px">
                <div class="input-group">
                    <input class="form-control" type="search" name="search" placeholder="Cari judul buku..." value="<%= typeof search !== 'undefined' ? search : '' %>">
                    <button class="btn btn-warning" type="submit"><i class="bi bi-search"></i></button>
                </div>
            </form>
            <ul class="navbar-nav ms-auto align-items-center gap-1">
                <!-- Kategori Dropdown -->
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                        <i class="bi bi-grid-3x3-gap me-1"></i>Kategori
                    </a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="/">Semua Buku</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="/?kategori=novel"><i class="bi bi-journal-text me-2 text-primary"></i>Novel</a></li>
                        <li><a class="dropdown-item" href="/?kategori=pendidikan"><i class="bi bi-mortarboard me-2 text-success"></i>Pendidikan</a></li>
                        <li><a class="dropdown-item" href="/?kategori=komik"><i class="bi bi-image me-2 text-danger"></i>Komik</a></li>
                    </ul>
                </li>
                <% if (user) { %>
                    <% if (user.role === 'user') { %>
                    <li class="nav-item">
                        <a class="nav-link position-relative" href="/keranjang">
                            <i class="bi bi-cart3 fs-5"></i>
                            <% if (typeof jumlahKeranjang !== 'undefined' && jumlahKeranjang > 0) { %>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size:.6rem">
                                <%= jumlahKeranjang %>
                            </span>
                            <% } %>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/pesanan"><i class="bi bi-bag-check me-1"></i>Pesanan</a>
                    </li>
                    <% } %>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle me-1"></i><%= user.nama.split(' ')[0] %>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <% if (user.role === 'admin') { %>
                            <li><a class="dropdown-item" href="/admin/dashboard"><i class="bi bi-speedometer2 me-2"></i>Dashboard Admin</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <% } %>
                            <li><a class="dropdown-item text-danger" href="/auth/logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
                        </ul>
                    </li>
                <% } else { %>
                    <li class="nav-item"><a class="nav-link" href="/auth/login">Login</a></li>
                    <li class="nav-item"><a class="btn btn-warning btn-sm ms-2 px-3" href="/auth/register">Daftar</a></li>
                <% } %>
            </ul>
        </div>
    </div>
</nav>

<!-- FLASH MESSAGES -->
<div class="container mt-3">
    <% if (success && success.length > 0) { %>
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i><%= success %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>
    <% if (error && error.length > 0) { %>
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i><%= error %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>
    <% if (info && info.length > 0) { %>
        <div class="alert alert-info alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-info-circle-fill me-2"></i><%= info %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>
</div>
