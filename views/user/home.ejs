<%- include('../partials/header') %>

<!-- HERO BANNER -->
<% if (!selectedKategori && !search) { %>
<section class="hero-section py-5 mb-4">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <span class="badge bg-warning text-dark mb-3 px-3 py-2">📚 Toko Buku Online</span>
                <h1 class="display-5 fw-bold mb-3">Temukan Buku <br><span class="text-primary">Favoritmu</span> di Sini</h1>
                <p class="text-muted lead mb-4">Ribuan judul buku pilihan — novel, pendidikan, komik — dengan harga terjangkau dan pengiriman cepat.</p>
                <div class="d-flex gap-3 flex-wrap">
                    <a href="/?kategori=novel" class="btn btn-primary px-4 py-2">
                        <i class="bi bi-journal-text me-2"></i>Jelajahi Novel
                    </a>
                    <a href="/?kategori=pendidikan" class="btn btn-outline-primary px-4 py-2">
                        <i class="bi bi-mortarboard me-2"></i>Buku Pendidikan
                    </a>
                </div>
            </div>
            <div class="col-lg-6 text-center d-none d-lg-block">
                <div class="hero-books-display">
                    <i class="bi bi-book-half" style="font-size:8rem;color:rgba(13,110,253,.15)"></i>
                </div>
            </div>
        </div>
    </div>
</section>
<% } %>

<div class="container mb-5">

    <!-- FILTER KATEGORI -->
    <div class="d-flex align-items-center gap-2 mb-4 flex-wrap">
        <a href="/" class="btn btn-sm <%= !selectedKategori ? 'btn-primary' : 'btn-outline-secondary' %> rounded-pill px-3">
            Semua
        </a>
        <a href="/?kategori=novel" class="btn btn-sm <%= selectedKategori === 'novel' ? 'btn-primary' : 'btn-outline-secondary' %> rounded-pill px-3">
            <i class="bi bi-journal-text me-1"></i>Novel
        </a>
        <a href="/?kategori=pendidikan" class="btn btn-sm <%= selectedKategori === 'pendidikan' ? 'btn-primary' : 'btn-outline-secondary' %> rounded-pill px-3">
            <i class="bi bi-mortarboard me-1"></i>Pendidikan
        </a>
        <a href="/?kategori=komik" class="btn btn-sm <%= selectedKategori === 'komik' ? 'btn-primary' : 'btn-outline-secondary' %> rounded-pill px-3">
            <i class="bi bi-image me-1"></i>Komik
        </a>
        <% if (search) { %>
        <span class="ms-auto text-muted small">Hasil pencarian: "<strong><%= search %></strong>"</span>
        <a href="/" class="btn btn-sm btn-outline-danger rounded-pill"><i class="bi bi-x me-1"></i>Hapus Filter</a>
        <% } %>
    </div>

    <!-- DAFTAR BUKU -->
    <% if (bukus.length === 0) { %>
    <div class="text-center py-5">
        <i class="bi bi-search" style="font-size:4rem;color:#dee2e6"></i>
        <h5 class="mt-3 text-muted">Buku tidak ditemukan</h5>
        <p class="text-muted">Coba kata kunci lain atau lihat semua buku</p>
        <a href="/" class="btn btn-primary mt-2">Lihat Semua Buku</a>
    </div>
    <% } else { %>
    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-3 mb-4">
        <% bukus.forEach(buku => { %>
        <div class="col">
            <div class="card buku-card h-100 border-0 shadow-sm">
                <div class="buku-img-wrap">
                    <img src="/images/<%= buku.gambar %>"
                         class="card-img-top buku-img"
                         alt="<%= buku.judul %>"
                         onerror="this.src='/images/default-book.jpg'">
                    <span class="buku-kategori-badge badge">
                        <%= buku.kategori ? buku.kategori.nama : '' %>
                    </span>
                    <% if (buku.stok === 0) { %>
                    <div class="stok-habis-overlay">Stok Habis</div>
                    <% } %>
                </div>
                <div class="card-body d-flex flex-column p-3">
                    <h6 class="card-title fw-semibold mb-1 buku-title"><%= buku.judul %></h6>
                    <small class="text-muted mb-2"><%= buku.penulis %></small>
                    <div class="mt-auto">
                        <div class="fw-bold text-primary mb-2"><%- formatRupiah(buku.harga) %></div>
                        <div class="d-flex gap-1">
                            <a href="/buku/<%= buku.id %>" class="btn btn-sm btn-outline-primary flex-grow-1">
                                <i class="bi bi-eye me-1"></i>Detail
                            </a>
                            <% if (buku.stok > 0) { %>
                            <form action="/keranjang/tambah" method="POST">
                                <input type="hidden" name="buku_id" value="<%= buku.id %>">
                                <input type="hidden" name="jumlah" value="1">
                                <button type="submit" class="btn btn-sm btn-primary" title="Tambah ke Keranjang"
                                    <%= !user || user.role === 'admin' ? 'onclick="return checkLogin(event)"' : '' %>>
                                    <i class="bi bi-cart-plus"></i>
                                </button>
                            </form>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <% }) %>
    </div>

    <!-- PAGINATION -->
    <% if (totalPages > 1) { %>
    <nav>
        <ul class="pagination justify-content-center">
            <li class="page-item <%= currentPage <= 1 ? 'disabled' : '' %>">
                <a class="page-link" href="?page=<%= currentPage - 1 %>&kategori=<%= selectedKategori %>&search=<%= search %>">
                    <i class="bi bi-chevron-left"></i>
                </a>
            </li>
            <% for (let i = 1; i <= totalPages; i++) { %>
            <li class="page-item <%= i === currentPage ? 'active' : '' %>">
                <a class="page-link" href="?page=<%= i %>&kategori=<%= selectedKategori %>&search=<%= search %>"><%= i %></a>
            </li>
            <% } %>
            <li class="page-item <%= currentPage >= totalPages ? 'disabled' : '' %>">
                <a class="page-link" href="?page=<%= currentPage + 1 %>&kategori=<%= selectedKategori %>&search=<%= search %>">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </li>
        </ul>
    </nav>
    <% } %>
    <% } %>
</div>

<%- include('../partials/footer') %>

<script>
function checkLogin(e) {
    <% if (!user) { %>
    e.preventDefault();
    if (confirm('Kamu perlu login untuk menambahkan ke keranjang. Login sekarang?')) {
        window.location.href = '/auth/login';
    }
    return false;
    <% } %>
}
</script>
