<%- include('../partials/header') %>

<div class="container py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Beranda</a></li>
            <li class="breadcrumb-item"><a href="/?kategori=<%= buku.kategori ? buku.kategori.slug : '' %>"><%= buku.kategori ? buku.kategori.nama : 'Kategori' %></a></li>
            <li class="breadcrumb-item active text-truncate" style="max-width:200px"><%= buku.judul %></li>
        </ol>
    </nav>

    <div class="row g-4">
        <!-- Gambar Buku -->
        <div class="col-md-4 col-lg-3">
            <div class="card border-0 shadow-sm p-3 text-center sticky-top" style="top:80px">
                <img src="/images/<%= buku.gambar %>" class="img-fluid rounded mb-3" alt="<%= buku.judul %>"
                     style="max-height:320px;object-fit:cover" onerror="this.src='/images/default-book.jpg'">
                <span class="badge bg-primary mb-2"><%= buku.kategori ? buku.kategori.nama : '' %></span>
                <% if (buku.stok > 0) { %>
                <span class="badge bg-success">Stok Tersedia: <%= buku.stok %></span>
                <% } else { %>
                <span class="badge bg-danger">Stok Habis</span>
                <% } %>
            </div>
        </div>

        <!-- Info Buku -->
        <div class="col-md-8 col-lg-9">
            <h2 class="fw-bold mb-1"><%= buku.judul %></h2>
            <p class="text-muted mb-3">oleh <strong><%= buku.penulis %></strong></p>

            <div class="row g-2 mb-4">
                <div class="col-sm-6 col-lg-3">
                    <div class="info-box p-3 rounded bg-light">
                        <small class="text-muted d-block">Penerbit</small>
                        <strong><%= buku.penerbit || '-' %></strong>
                    </div>
                </div>
                <div class="col-sm-6 col-lg-3">
                    <div class="info-box p-3 rounded bg-light">
                        <small class="text-muted d-block">Tahun Terbit</small>
                        <strong><%= buku.tahun_terbit || '-' %></strong>
                    </div>
                </div>
                <div class="col-sm-6 col-lg-3">
                    <div class="info-box p-3 rounded bg-light">
                        <small class="text-muted d-block">ISBN</small>
                        <strong><%= buku.isbn || '-' %></strong>
                    </div>
                </div>
                <div class="col-sm-6 col-lg-3">
                    <div class="info-box p-3 rounded bg-light">
                        <small class="text-muted d-block">Kategori</small>
                        <strong><%= buku.kategori ? buku.kategori.nama : '-' %></strong>
                    </div>
                </div>
            </div>

            <div class="mb-4">
                <h3 class="text-primary fw-bold"><%- formatRupiah(buku.harga) %></h3>
            </div>

            <% if (buku.deskripsi) { %>
            <div class="mb-4">
                <h6 class="fw-semibold mb-2">Deskripsi Buku</h6>
                <p class="text-muted lh-lg"><%= buku.deskripsi %></p>
            </div>
            <% } %>

            <!-- Aksi -->
            <% if (buku.stok > 0) { %>
            <form action="/keranjang/tambah" method="POST" class="d-flex align-items-center gap-3 flex-wrap">
                <input type="hidden" name="buku_id" value="<%= buku.id %>">
                <div class="input-group" style="width:130px">
                    <button class="btn btn-outline-secondary" type="button" onclick="changeQty(-1)">-</button>
                    <input type="number" class="form-control text-center" name="jumlah" id="qtyInput" value="1" min="1" max="<%= buku.stok %>">
                    <button class="btn btn-outline-secondary" type="button" onclick="changeQty(1)">+</button>
                </div>
                <button type="submit" class="btn btn-primary px-4 py-2 fw-semibold"
                    <%= !user || user.role === 'admin' ? 'onclick="return confirmLogin(event)"' : '' %>>
                    <i class="bi bi-cart-plus me-2"></i>Tambah ke Keranjang
                </button>
                <% if (user && user.role === 'user') { %>
                <a href="/keranjang" class="btn btn-outline-primary px-4 py-2">
                    <i class="bi bi-bag me-1"></i>Lihat Keranjang
                </a>
                <% } %>
            </form>
            <% } else { %>
            <div class="alert alert-warning"><i class="bi bi-exclamation-triangle me-2"></i>Maaf, stok buku ini sedang habis.</div>
            <% } %>
        </div>
    </div>

    <!-- Buku Terkait -->
    <% if (related.length > 0) { %>
    <hr class="my-5">
    <h5 class="fw-bold mb-3">Buku Terkait</h5>
    <div class="row row-cols-2 row-cols-md-4 g-3">
        <% related.forEach(r => { %>
        <div class="col">
            <div class="card buku-card h-100 border-0 shadow-sm">
                <div class="buku-img-wrap">
                    <img src="/images/<%= r.gambar %>" class="card-img-top buku-img" alt="<%= r.judul %>"
                         onerror="this.src='/images/default-book.jpg'">
                </div>
                <div class="card-body p-3">
                    <h6 class="fw-semibold buku-title mb-1"><%= r.judul %></h6>
                    <small class="text-muted"><%= r.penulis %></small>
                    <div class="fw-bold text-primary mt-2 mb-2"><%- formatRupiah(r.harga) %></div>
                    <a href="/buku/<%= r.id %>" class="btn btn-sm btn-outline-primary w-100">Lihat Detail</a>
                </div>
            </div>
        </div>
        <% }) %>
    </div>
    <% } %>
</div>

<%- include('../partials/footer') %>
<script>
function changeQty(delta) {
    const input = document.getElementById('qtyInput');
    const newVal = parseInt(input.value) + delta;
    if (newVal >= 1 && newVal <= parseInt(input.max)) input.value = newVal;
}
function confirmLogin(e) {
    <% if (!user) { %>
    e.preventDefault();
    if (confirm('Login terlebih dahulu untuk menambah ke keranjang.')) window.location.href = '/auth/login';
    return false;
    <% } %>
}
</script>
