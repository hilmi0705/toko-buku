<%- include('../partials/header') %>

<div class="container py-4">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/pesanan" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
        <h4 class="fw-bold mb-0">Detail Pesanan</h4>
    </div>

    <%
    const statusMap = { 'menunggu':'warning','diproses':'info','dikirim':'primary','selesai':'success','dibatalkan':'danger' };
    const statusLabel = { 'menunggu':'Menunggu Konfirmasi','diproses':'Sedang Diproses','dikirim':'Sedang Dikirim','selesai':'Pesanan Selesai','dibatalkan':'Dibatalkan' };
    %>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                        <div>
                            <h6 class="fw-bold mb-1"><%= pesanan.kode_pesanan %></h6>
                            <small class="text-muted">Dipesan: <%= formatTanggal(pesanan.createdAt) %></small>
                        </div>
                        <span class="badge bg-<%= statusMap[pesanan.status] %> fs-6 px-3 py-2">
                            <%= statusLabel[pesanan.status] %>
                        </span>
                    </div>

                    <div class="mb-3 p-3 bg-light rounded">
                        <small class="text-muted fw-medium d-block mb-1"><i class="bi bi-geo-alt me-1"></i>Alamat Pengiriman</small>
                        <span><%= pesanan.alamat_pengiriman %></span>
                        <% if (pesanan.catatan) { %>
                        <div class="mt-2"><small class="text-muted">Catatan: <%= pesanan.catatan %></small></div>
                        <% } %>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold py-3">Daftar Produk</div>
                <div class="card-body p-0">
                    <% pesanan.details.forEach((d, idx) => { %>
                    <div class="d-flex align-items-center p-3 <%= idx < pesanan.details.length - 1 ? 'border-bottom' : '' %>">
                        <img src="/images/<%= d.buku.gambar %>" alt="" class="rounded me-3"
                             style="width:60px;height:76px;object-fit:cover" onerror="this.src='/images/default-book.jpg'">
                        <div class="flex-grow-1">
                            <div class="fw-semibold"><%= d.buku.judul %></div>
                            <small class="text-muted"><%= d.jumlah %> × <%- formatRupiah(d.harga_satuan) %></small>
                        </div>
                        <strong><%- formatRupiah(d.subtotal) %></strong>
                    </div>
                    <% }) %>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3">Ringkasan Pembayaran</h6>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Subtotal Produk</span>
                        <span><%- formatRupiah(pesanan.total_harga) %></span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Ongkir</span>
                        <span class="text-success">Gratis</span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between">
                        <strong>Total</strong>
                        <strong class="text-primary fs-5"><%- formatRupiah(pesanan.total_harga) %></strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
