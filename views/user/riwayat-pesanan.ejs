<%- include('../partials/header') %>

<div class="container py-4">
    <h4 class="fw-bold mb-4"><i class="bi bi-bag me-2"></i>Riwayat Pesanan</h4>

    <% if (pesanans.length === 0) { %>
    <div class="text-center py-5">
        <i class="bi bi-bag-x" style="font-size:5rem;color:#dee2e6"></i>
        <h5 class="mt-3 text-muted">Belum ada pesanan</h5>
        <a href="/" class="btn btn-primary mt-2 px-4"><i class="bi bi-shop me-2"></i>Mulai Belanja</a>
    </div>
    <% } else { %>
    <div class="row g-3">
        <% pesanans.forEach(p => { %>
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white d-flex justify-content-between align-items-center py-3 flex-wrap gap-2">
                    <div>
                        <span class="fw-semibold me-3"><%= p.kode_pesanan %></span>
                        <small class="text-muted"><%= formatTanggal(p.createdAt) %></small>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <%
                        const statusMap = {
                            'menunggu': 'warning',
                            'diproses': 'info',
                            'dikirim': 'primary',
                            'selesai': 'success',
                            'dibatalkan': 'danger'
                        };
                        const statusLabel = {
                            'menunggu': 'Menunggu',
                            'diproses': 'Diproses',
                            'dikirim': 'Dikirim',
                            'selesai': 'Selesai',
                            'dibatalkan': 'Dibatalkan'
                        };
                        %>
                        <span class="badge bg-<%= statusMap[p.status] || 'secondary' %> px-3 py-2">
                            <%= statusLabel[p.status] || p.status %>
                        </span>
                        <a href="/pesanan/<%= p.id %>" class="btn btn-sm btn-outline-primary">Detail</a>
                    </div>
                </div>
                <div class="card-body p-3">
                    <div class="d-flex flex-wrap gap-3 align-items-center justify-content-between">
                        <div class="d-flex gap-2 flex-wrap">
                            <% p.details.slice(0, 3).forEach(d => { %>
                            <div class="d-flex align-items-center gap-2">
                                <img src="/images/<%= d.buku.gambar %>" alt="" class="rounded"
                                     style="width:45px;height:58px;object-fit:cover" onerror="this.src='/images/default-book.jpg'">
                                <div>
                                    <div class="small fw-medium"><%= d.buku.judul.length > 25 ? d.buku.judul.substring(0,25)+'...' : d.buku.judul %></div>
                                    <small class="text-muted"><%= d.jumlah %> buku</small>
                                </div>
                            </div>
                            <% }) %>
                            <% if (p.details.length > 3) { %>
                            <div class="d-flex align-items-center">
                                <span class="text-muted small">+<%= p.details.length - 3 %> buku lainnya</span>
                            </div>
                            <% } %>
                        </div>
                        <div class="text-end">
                            <small class="text-muted d-block">Total Pembayaran</small>
                            <strong class="text-primary fs-6"><%- formatRupiah(p.total_harga) %></strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <% }) %>
    </div>
    <% } %>
</div>

<%- include('../partials/footer') %>
