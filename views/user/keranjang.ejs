<%- include('../partials/header') %>

<div class="container py-4">
    <h4 class="fw-bold mb-4"><i class="bi bi-cart3 me-2"></i>Keranjang Belanja</h4>

    <% if (items.length === 0) { %>
    <div class="text-center py-5">
        <i class="bi bi-cart-x" style="font-size:5rem;color:#dee2e6"></i>
        <h5 class="mt-3 text-muted">Keranjang kamu kosong</h5>
        <p class="text-muted">Temukan buku menarik dan tambahkan ke keranjang!</p>
        <a href="/" class="btn btn-primary mt-2 px-4"><i class="bi bi-shop me-2"></i>Belanja Sekarang</a>
    </div>
    <% } else { %>
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-0">
                    <% items.forEach((item, idx) => { %>
                    <div class="keranjang-item d-flex align-items-center p-3 <%= idx < items.length - 1 ? 'border-bottom' : '' %>">
                        <img src="/images/<%= item.buku.gambar %>" alt="<%= item.buku.judul %>"
                             class="rounded me-3" style="width:70px;height:90px;object-fit:cover"
                             onerror="this.src='/images/default-book.jpg'">
                        <div class="flex-grow-1">
                            <h6 class="fw-semibold mb-1"><a href="/buku/<%= item.buku.id %>" class="text-decoration-none text-dark"><%= item.buku.judul %></a></h6>
                            <small class="text-muted"><%= item.buku.penulis %></small>
                            <div class="text-primary fw-bold mt-1"><%- formatRupiah(item.buku.harga) %></div>
                        </div>
                        <div class="d-flex align-items-center gap-3 flex-wrap">
                            <!-- Update Jumlah -->
                            <form action="/keranjang/update" method="POST" class="d-flex align-items-center">
                                <input type="hidden" name="id" value="<%= item.id %>">
                                <div class="input-group input-group-sm" style="width:110px">
                                    <button class="btn btn-outline-secondary" type="button" onclick="this.form.jumlah.value = Math.max(0, parseInt(this.form.jumlah.value)-1); this.form.submit()">-</button>
                                    <input type="number" class="form-control text-center" name="jumlah" value="<%= item.jumlah %>" min="0" max="<%= item.buku.stok %>">
                                    <button class="btn btn-outline-secondary" type="button" onclick="this.form.jumlah.value = Math.min(<%= item.buku.stok %>, parseInt(this.form.jumlah.value)+1); this.form.submit()">+</button>
                                </div>
                            </form>
                            <div class="fw-bold" style="min-width:90px;text-align:right">
                                <%- formatRupiah(item.jumlah * item.buku.harga) %>
                            </div>
                            <!-- Hapus -->
                            <form action="/keranjang/hapus/<%= item.id %>" method="POST">
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Hapus">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                    <% }) %>
                </div>
            </div>
        </div>

        <!-- Ringkasan -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm sticky-top" style="top:80px">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3">Ringkasan Belanja</h6>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Subtotal (<%= items.length %> item)</span>
                        <span><%- formatRupiah(total) %></span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Ongkir</span>
                        <span class="text-success">Gratis</span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between mb-3">
                        <strong>Total</strong>
                        <strong class="text-primary fs-5"><%- formatRupiah(total) %></strong>
                    </div>
                    <a href="/checkout" class="btn btn-primary w-100 py-2 fw-semibold">
                        <i class="bi bi-bag-check me-2"></i>Checkout Sekarang
                    </a>
                    <a href="/" class="btn btn-outline-secondary w-100 mt-2">
                        <i class="bi bi-arrow-left me-1"></i>Lanjut Belanja
                    </a>
                </div>
            </div>
        </div>
    </div>
    <% } %>
</div>

<%- include('../partials/footer') %>
