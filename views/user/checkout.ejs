<%- include('../partials/header') %>

<div class="container py-4">
    <h4 class="fw-bold mb-4"><i class="bi bi-bag-check me-2"></i>Checkout Pesanan</h4>

    <form action="/checkout" method="POST">
    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white fw-semibold py-3"><i class="bi bi-geo-alt me-2 text-primary"></i>Alamat Pengiriman</div>
                <div class="card-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-medium">Alamat Lengkap <span class="text-danger">*</span></label>
                        <textarea class="form-control" name="alamat_pengiriman" rows="3"
                            placeholder="Masukkan alamat pengiriman lengkap" required><%= userDetail && userDetail.alamat ? userDetail.alamat : '' %></textarea>
                    </div>
                    <div class="mb-1">
                        <label class="form-label fw-medium">Catatan (opsional)</label>
                        <input type="text" class="form-control" name="catatan" placeholder="Catatan untuk penjual">
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold py-3"><i class="bi bi-box-seam me-2 text-primary"></i>Daftar Produk</div>
                <div class="card-body p-0">
                    <% items.forEach((item, idx) => { %>
                    <div class="d-flex align-items-center p-3 <%= idx < items.length - 1 ? 'border-bottom' : '' %>">
                        <img src="/images/<%= item.buku.gambar %>" alt="" class="rounded me-3"
                             style="width:50px;height:65px;object-fit:cover" onerror="this.src='/images/default-book.jpg'">
                        <div class="flex-grow-1">
                            <div class="fw-semibold"><%= item.buku.judul %></div>
                            <small class="text-muted"><%= item.jumlah %> × <%- formatRupiah(item.buku.harga) %></small>
                        </div>
                        <strong><%- formatRupiah(item.jumlah * item.buku.harga) %></strong>
                    </div>
                    <% }) %>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card border-0 shadow-sm sticky-top" style="top:80px">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3">Ringkasan Pesanan</h6>
                    <% items.forEach(item => { %>
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted small text-truncate" style="max-width:180px"><%= item.buku.judul %> ×<%= item.jumlah %></span>
                        <span class="small"><%- formatRupiah(item.jumlah * item.buku.harga) %></span>
                    </div>
                    <% }) %>
                    <hr>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Ongkos Kirim</span>
                        <span class="text-success fw-medium">Gratis</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <strong class="fs-5">Total</strong>
                        <strong class="text-primary fs-5"><%- formatRupiah(total) %></strong>
                    </div>
                    <div class="alert alert-info py-2 small mb-3">
                        <i class="bi bi-info-circle me-1"></i>Pembayaran dilakukan setelah konfirmasi admin.
                    </div>
                    <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                        <i class="bi bi-check-circle me-2"></i>Buat Pesanan
                    </button>
                    <a href="/keranjang" class="btn btn-outline-secondary w-100 mt-2">
                        <i class="bi bi-arrow-left me-1"></i>Kembali ke Keranjang
                    </a>
                </div>
            </div>
        </div>
    </div>
    </form>
</div>

<%- include('../partials/footer') %>
